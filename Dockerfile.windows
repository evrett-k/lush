# Use a rust image with mingw-w64 for cross-compilation
FROM rust:1.80-alpine AS builder
RUN apk add --no-cache mingw-w64-gcc gcc musl-dev
WORKDIR /app
COPY . .

# Build for Windows (using x86_64-pc-windows-gnu for easier cross-compilation on alpine)
RUN rustup target add x86_64-pc-windows-gnu
RUN cargo build --release --target x86_64-pc-windows-gnu

FROM alpine:latest
COPY --from=builder /app/target/x86_64-pc-windows-gnu/release/lush.exe /app/lush.exe
ENTRYPOINT ["/app/lush.exe"]
